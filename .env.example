# IronClaw Go 环境变量示例

# 应用环境: development, staging, production
IRONCLAW_ENV=development

# 数据库 (MVP 使用内存，后续切换)
# DATABASE_URL=postgres://ironclaw:ironclaw@localhost:5432/ironclaw

# 所有者 ID
IRONCLAW_OWNER_ID=owner_001

# Agent 配置
IRONCLAW_AGENT_NAME=IronClaw
IRONCLAW_AGENT_MAX_PARALLEL_JOBS=4

# gRPC Sidecar 地址
IRONCLAW_SIDECAR_ADDR=unix:///tmp/ironclaw-sidecar.sock

# 日志级别: trace, debug, info, warn, error
RUST_LOG=info
