# MiniMax API Key（请替换为你的真实 key）
export MINIMAX_API_KEY=sk-your-key-here

# LLM 配置（使用 MiniMax）
export IRONCLAW_LLM_PROVIDER=minimax
export IRONCLAW_LLM_MODEL=MiniMax-M2.7
export IRONCLAW_LLM_API_KEY=$MINIMAX_API_KEY
export IRONCLAW_LLM_BASE_URL=https://api.minimax.chat/v1

# 本地开发常用配置
export IRONCLAW_ENV=development
export IRONCLAW_DATABASE_DRIVER=memory
export IRONCLAW_CHANNELS_HTTP=true
export IRONCLAW_CHANNELS_HTTP_PORT=8080
export IRONCLAW_AGENT_NAME=IronClaw
